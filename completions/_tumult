# --- Per-command completion functions ---

_720p() {
  _arguments '1:application name:_mac_applications'
}

_bundle-id() {
  _arguments '1:application name:_mac_applications'
}

_change-wallpaper() {
  _message 'no arguments required (forces wallpaper rotation)'
}

_chrome() {
  _arguments '1:URL or search term:'
}

_clip() {
  _arguments '*:file:_files'
}

_darktoggle() {
  _message 'no arguments required (toggles dark mode)'
}

_dump-entitlements() {
  local -a subcommands
  subcommands=(
    'find:find binaries with entitlements'
    'dump:dump entitlements for a binary'
    'sort:sort entitlements output'
    'help:show usage information'
  )
  _describe -t subcommands 'dump-entitlements subcommand' subcommands
}

_get-keychain-generic-password() {
  _arguments '1:secret name:'
}

_google() {
  _arguments '*:search terms:'
}

_hide-file() {
  _arguments '*:file:_files'
}

_imgcat() {
  _arguments \
    '(-h --help)'{-h,--help}'[display help message]' \
    '(-p --print)'{-p,--print}'[print filename after each image]' \
    '(-n --no-print)'{-n,--no-print}'[disable printing of filename]' \
    '(-W --width)'{-W,--width}'[set image width]:width (N, Npx, N%, auto):' \
    '(-H --height)'{-H,--height}'[set image height]:height (N, Npx, N%, auto):' \
    '(-r --preserve-aspect-ratio)'{-r,--preserve-aspect-ratio}'[preserve aspect ratio when scaling]' \
    '(-s --stretch)'{-s,--stretch}'[stretch image to specified dimensions]' \
    '(-f --file)'{-f,--file}'[interpret arguments as files]' \
    '(-u --url)'{-u,--url}'[interpret arguments as URLs]' \
    '(-t --type)'{-t,--type}'[provide a file type hint]:file type:' \
    '*:image file:_files -g "*(#i).(png|jpg|jpeg|gif|bmp|tiff|webp|svg|ico)"'
}

_itunesctl() {
  local -a subcommands
  subcommands=(
    'play:start playback'
    'pause:pause playback'
    'mute:mute audio'
    'unmute:unmute audio'
    'next:skip to the next track'
    'prev:go to the previous track'
  )
  _describe -t subcommands 'itunesctl command' subcommands
}

_keychainctl() {
  local -a subcommands
  subcommands=(
    'get:retrieve a secret from the keychain'
    'set:store a secret in the keychain'
    'rm:delete a secret from the keychain'
    'ls:list all secrets in the keychain'
    'lock:lock the keychain'
  )
  if (( CURRENT == 2 )); then
    _describe -t subcommands 'keychainctl subcommand' subcommands
  elif (( CURRENT == 3 )); then
    case "${words[2]}" in
      get|set|rm)
        _message 'secret name'
        ;;
    esac
  fi
}

_mac-alert() {
  _arguments '1:alert title:' '2:alert body:'
}

_macos-alert() {
  _arguments '1:alert title:' '2:alert body:'
}

_mac-notification() {
  _macos-notification "$@"
}

_macos-notification() {
  _arguments \
    '1:notification title:' \
    '2:subtitle:' \
    '3:sound name:' \
    '4:notification text:'
}

_macos-dialog() {
  _arguments '1:dialog text:'
}

_make-ramdisk() {
  _arguments \
    '(-h --help)'{-h,--help}'[display help]' \
    '--ram-disk-name[name for the RAM disk]:disk name:' \
    '--ramdisk-name[name for the RAM disk]:disk name:' \
    '--ram-disk-size[size in megabytes]:size in MB:' \
    '--ramdisk-size[size in megabytes]:size in MB:'
}

_manpreview() {
  _arguments '*:man page:_man'
}

_manp() {
  _arguments '*:man page:_man'
}

_markdown-open() {
  _arguments '1:markdown file:_files -g "*(#i).(md|markdown|txt)"'
}

_mergepdfs() {
  _arguments \
    '-o[output file]:output PDF:_files -g "*.pdf"' \
    '*:input PDF files:_files -g "*.pdf"'
}

_mkdmg() {
  _arguments '1:volume name:' '2:source directory:_directories'
}

_mkicns() {
  _arguments '1:source image:_files -g "*(#i).(png|jpg|jpeg|tiff|gif)"'
}

_pbsed() {
  _arguments '*:sed expression:'
}

_pb-sed() {
  _arguments '*:sed expression:'
}

_pledit() {
  _arguments '1:plist file:_files -g "*.plist"'
}

_quicklook() {
  _arguments '*:file:_files'
}

_screencap-stream() {
  _arguments \
    '-i[interval between frame captures]:seconds:' \
    '-k[keep captured frames as snapshots]' \
    '-o[output movie name]:movie file:_files -g "*.mp4"' \
    '-t[target directory for retained frames]:directory:_directories'
}

_set-cursor-size() {
  local -a sizes
  sizes=(
    '1:smallest'
    '1.5:small'
    '2:medium'
    '2.5:large'
    '3:larger'
    '3.5:very large'
    '4:largest'
  )
  _describe -t sizes 'cursor size' sizes
}

_set-macos-hostname() {
  _arguments '1:new hostname:'
}

_set-osx-hostname() {
  _arguments '1:new hostname:'
}

_set-mojave-disk-warning-threshold() {
  _arguments '1:threshold in GB:'
}

_set-software-update-interval() {
  local -a intervals
  intervals=(
    '1:every day'
    '3:every 3 days'
    '7:weekly'
    '14:every 2 weeks'
    '30:monthly'
  )
  _describe -t intervals 'update check interval (days)' intervals
}

_set-time-machine-interval() {
  local -a intervals
  intervals=(
    '1800:every 30 minutes'
    '3600:every hour'
    '7200:every 2 hours'
    '14400:every 4 hours'
    '43200:every 12 hours'
    '86400:every 24 hours'
  )
  _describe -t intervals 'backup interval (seconds)' intervals
}

_set-wallpaper() {
  _arguments '1:image file:_files -g "*(#i).(png|jpg|jpeg|tiff|gif|heic)"'
}

_time-machine-throttle() {
  _message 'no arguments required (throttles Time Machine)'
}

_toggle-ssh() {
  _message 'no arguments required (toggles SSH server)'
}

_unfuck-captive-portal() {
  _message 'no arguments required'
}

_unhide-file() {
  _arguments '*:file:_files'
}

_unquarantine() {
  _arguments '*:file:_files'
}

_volume() {
  local -a levels
  levels=(
    '0:mute'
    '10:barely audible'
    '20:very quiet'
    '30:quiet'
    '40:low'
    '50:medium'
    '60:moderate'
    '70:loud'
    '80:very loud'
    '90:near maximum'
    '100:maximum'
  )
  _describe -t levels 'volume level (0-100)' levels
}

_wifi() {
  local -a states
  states=(
    'on:enable Wi-Fi'
    'off:disable Wi-Fi'
  )
  _describe -t states 'Wi-Fi state' states
}

# --- Helper functions ---

_mac_applications() {
  local -a apps
  apps=( ${(f)"$(find /Applications -maxdepth 2 -name '*.app' -exec basename {} .app \; 2>/dev/null)"} )
  _describe -t applications 'application' apps
}

# --- Dispatcher ---

local cmd=${service}

if (( $+functions[_${cmd}] )); then
  _${cmd} "$@"
else
  _message "no specific completion available"
fi
