# Zsh completions for tumult plugin scripts
# https://github.com/unixorn/tumult.plugin.zsh
#
# Provides:
#   - Per-command argument completions with descriptions
#   - A top-level _tumult_commands function for browsing all available commands

# Top-level command listing with descriptions (useful for enumeration or wrapper commands)
_tumult_commands() {
